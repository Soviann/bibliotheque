{#
    Filters component
    Variables:
    - route: string (app_home or app_wishlist)
    - currentType: ComicType|null
    - currentStatus: ComicStatus|null (optional)
    - currentNas: string|null ('1', '0', or null)
    - currentSort: string
    - currentSearch: string
    - types: ComicType[]
    - statuses: ComicStatus[] (optional)
#}

<div class="filters-container">
    {# Search input #}
    <div class="filter-search">
        <form action="{{ path(route) }}" method="get" class="search-filter-form">
            {# Preserve current filters #}
            {% if currentType %}<input type="hidden" name="type" value="{{ currentType.value }}">{% endif %}
            {% if currentStatus is defined and currentStatus %}<input type="hidden" name="status" value="{{ currentStatus.value }}">{% endif %}
            {% if currentNas is not null %}<input type="hidden" name="nas" value="{{ currentNas }}">{% endif %}
            <input type="hidden" name="sort" value="{{ currentSort }}">

            <div class="search-input-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                    <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                </svg>
                <input
                    type="search"
                    name="q"
                    value="{{ currentSearch }}"
                    placeholder="Rechercher..."
                    class="search-filter-input"
                    {{ stimulus_target('library', 'searchInput') }}
                >
                {% if currentSearch %}
                    <a href="{{ path(route, {
                        type: currentType ? currentType.value : null,
                        status: (currentStatus is defined and currentStatus) ? currentStatus.value : null,
                        nas: currentNas,
                        sort: currentSort
                    }|filter(v => v is not null)) }}" class="search-clear">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                        </svg>
                    </a>
                {% endif %}
            </div>
        </form>
    </div>

    {# Sort dropdown #}
    <div class="filter-sort">
        <label for="sort-select" class="filter-label">Trier par</label>
        <select id="sort-select" class="sort-select" onchange="updateSort(this.value)">
            <option value="title_asc" {% if currentSort == 'title_asc' %}selected{% endif %}>Titre A-Z</option>
            <option value="title_desc" {% if currentSort == 'title_desc' %}selected{% endif %}>Titre Z-A</option>
            <option value="updated_desc" {% if currentSort == 'updated_desc' %}selected{% endif %}>Modifie recemment</option>
            <option value="updated_asc" {% if currentSort == 'updated_asc' %}selected{% endif %}>Modifie anciennement</option>
            <option value="status" {% if currentSort == 'status' %}selected{% endif %}>Statut</option>
        </select>
    </div>

    {# Type chips #}
    <div class="filter-section">
        <span class="filter-label">Type</span>
        <div class="chips-container">
            <a href="{{ path(route, {
                q: currentSearch ?: null,
                status: (currentStatus is defined and currentStatus) ? currentStatus.value : null,
                nas: currentNas,
                sort: currentSort
            }|filter(v => v is not null)) }}" class="chip {% if currentType is null %}active{% endif %}">Tous</a>
            {% for type in types %}
                <a href="{{ path(route, {
                    type: type.value,
                    q: currentSearch ?: null,
                    status: (currentStatus is defined and currentStatus) ? currentStatus.value : null,
                    nas: currentNas,
                    sort: currentSort
                }|filter(v => v is not null)) }}" class="chip {% if currentType == type %}active{% endif %}">{{ type.label }}</a>
            {% endfor %}
        </div>
    </div>

    {# Status chips (only for library) #}
    {% if statuses is defined and statuses %}
        <div class="filter-section">
            <span class="filter-label">Statut</span>
            <div class="chips-container">
                <a href="{{ path(route, {
                    type: currentType ? currentType.value : null,
                    q: currentSearch ?: null,
                    nas: currentNas,
                    sort: currentSort
                }|filter(v => v is not null)) }}" class="chip {% if currentStatus is null %}active{% endif %}">Tous</a>
                {% for status in statuses %}
                    <a href="{{ path(route, {
                        type: currentType ? currentType.value : null,
                        status: status.value,
                        q: currentSearch ?: null,
                        nas: currentNas,
                        sort: currentSort
                    }|filter(v => v is not null)) }}" class="chip {% if currentStatus == status %}active{% endif %}">{{ status.label }}</a>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# NAS chips #}
    <div class="filter-section">
        <span class="filter-label">NAS</span>
        <div class="chips-container">
            <a href="{{ path(route, {
                type: currentType ? currentType.value : null,
                status: (currentStatus is defined and currentStatus) ? currentStatus.value : null,
                q: currentSearch ?: null,
                sort: currentSort
            }|filter(v => v is not null)) }}" class="chip {% if currentNas is null %}active{% endif %}">Tous</a>
            <a href="{{ path(route, {
                type: currentType ? currentType.value : null,
                status: (currentStatus is defined and currentStatus) ? currentStatus.value : null,
                q: currentSearch ?: null,
                nas: '1',
                sort: currentSort
            }|filter(v => v is not null)) }}" class="chip {% if currentNas == '1' %}active{% endif %}">Sur NAS</a>
            <a href="{{ path(route, {
                type: currentType ? currentType.value : null,
                status: (currentStatus is defined and currentStatus) ? currentStatus.value : null,
                q: currentSearch ?: null,
                nas: '0',
                sort: currentSort
            }|filter(v => v is not null)) }}" class="chip {% if currentNas == '0' %}active{% endif %}">Pas sur NAS</a>
        </div>
    </div>
</div>

<script>
function updateSort(value) {
    const url = new URL(window.location.href);
    url.searchParams.set('sort', value);
    window.location.href = url.toString();
}
</script>
