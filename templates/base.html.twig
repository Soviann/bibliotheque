<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
        <title>{% block title %}Ma Bibliotheque BD{% endblock %}</title>
        <link rel="icon" href="{{ asset('favicon.png') }}">
        {{ pwa() }}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body {{ stimulus_controller('pwa--connection-status', {
        onlineMessage: '',
        offlineMessage: 'Mode hors ligne'
    }) }} data-pwa--connection-status-target="attribute">
        <div class="app-container">
            {% if app.user %}
            {# Top App Bar - Desktop only #}
            <header class="top-app-bar">
                <div class="top-app-bar-title">Ma Bibliotheque BD</div>
                <nav class="top-app-bar-nav">
                    <a href="{{ path('app_home') }}" class="{% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}">Bibliotheque</a>
                    <a href="{{ path('app_wishlist') }}" class="{% if app.request.attributes.get('_route') == 'app_wishlist' %}active{% endif %}">Wishlist</a>
                    <a href="{{ path('app_search') }}" class="{% if app.request.attributes.get('_route') == 'app_search' %}active{% endif %}">Recherche</a>
                    <a href="{{ path('app_logout') }}">Deconnexion</a>
                </nav>
            </header>
            {% endif %}

            <main class="main-content">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="alert alert-error">{{ message }}</div>
                {% endfor %}

                {% block body %}{% endblock %}
            </main>

            {% if app.user %}
            {# FAB - Add new comic #}
            <a href="{{ path('app_comic_new') }}" class="fab" aria-label="Ajouter une serie" data-turbo-frame="_top">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                </svg>
            </a>

            {# Bottom Navigation - Mobile only #}
            <nav class="bottom-nav">
                <a href="{{ path('app_home') }}" class="bottom-nav-item {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                    </svg>
                    <span>Biblio</span>
                </a>
                <a href="{{ path('app_wishlist') }}" class="bottom-nav-item {% if app.request.attributes.get('_route') == 'app_wishlist' %}active{% endif %}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                    </svg>
                    <span>Wishlist</span>
                </a>
                <a href="{{ path('app_search') }}" class="bottom-nav-item {% if app.request.attributes.get('_route') == 'app_search' %}active{% endif %}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    </svg>
                    <span>Recherche</span>
                </a>
            </nav>
            {% endif %}

            <div id="offline-indicator" class="offline-indicator" data-pwa--connection-status-target="message"></div>
        </div>

    </body>
</html>
