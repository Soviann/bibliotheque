{% extends 'base.html.twig' %}

{% block title %}Wishlist - Ma Bibliotheque BD{% endblock %}

{% block body %}
<div {{ stimulus_controller('library', { isWishlist: true }) }}>
    <div class="page-header">
        <h1>Liste de souhaits</h1>
        <p class="text-subtitle" {{ stimulus_target('library', 'count') }}>{{ comics|length }} serie(s)</p>
    </div>

    {% include 'components/_filters.html.twig' with {
        route: 'app_wishlist',
        currentType: currentType,
        currentNas: currentNas,
        currentSort: currentSort,
        currentSearch: currentSearch,
        types: types
    } %}

    <div {{ stimulus_target('library', 'results') }}>
        {% if comics|length > 0 %}
            <div class="cards-grid">
                {% for comic in comics %}
                    {% include 'comic/_card.html.twig' with {comic: comic, showToLibrary: true} %}
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state">
                <p>Aucune serie trouvee dans la liste de souhaits.</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
