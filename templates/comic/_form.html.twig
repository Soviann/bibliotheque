{{ form_start(form, {attr: {class: 'comic-form', 'data-controller': 'comic-form tomes-collection'}}) }}
    <div class="form-row">
        <div class="mdc-text-field">
            <label for="{{ form.title.vars.id }}">Titre de la serie</label>
            {{ form_widget(form.title, {attr: {'data-comic-form-target': 'title'}}) }}
            {{ form_errors(form.title) }}
        </div>
    </div>

    <div class="form-row">
        <div class="mdc-text-field mdc-text-field--autocomplete" data-comic-form-target="authorsWrapper">
            <label for="{{ form.authors.vars.id }}">Auteur(s)</label>
            {{ form_widget(form.authors) }}
            {{ form_errors(form.authors) }}
        </div>

        <div class="mdc-text-field">
            <label for="{{ form.publisher.vars.id }}">Editeur</label>
            {{ form_widget(form.publisher, {attr: {'data-comic-form-target': 'publisher'}}) }}
            {{ form_errors(form.publisher) }}
        </div>
    </div>

    <div class="form-row">
        <div class="mdc-text-field">
            <label for="{{ form.publishedDate.vars.id }}">Date de publication</label>
            {{ form_widget(form.publishedDate, {attr: {'data-comic-form-target': 'publishedDate'}}) }}
            {{ form_errors(form.publishedDate) }}
        </div>

        <div class="mdc-text-field">
            <label for="{{ form.coverUrl.vars.id }}">URL de la couverture (externe)</label>
            {{ form_widget(form.coverUrl, {attr: {'data-comic-form-target': 'coverUrl'}}) }}
            {{ form_errors(form.coverUrl) }}
        </div>
    </div>

    <div class="form-row cover-upload-section">
        <div class="mdc-text-field mdc-text-field--full-width cover-upload-field">
            <label>Image de couverture (upload manuel)</label>
            {% if form.vars.data.coverImage %}
                <div class="current-cover">
                    <img src="{{ vich_uploader_asset(form.vars.data, 'coverFile') }}" alt="Couverture actuelle">
                    <small>Image actuelle (sera remplacee si vous uploadez une nouvelle image)</small>
                </div>
            {% endif %}
            {{ form_widget(form.coverFile) }}
            {{ form_errors(form.coverFile) }}
            <small class="form-hint">Glissez une image ou cliquez pour parcourir. Formats : JPEG, PNG, GIF, WebP. Max : 5 Mo.</small>
        </div>
    </div>

    <div class="mdc-text-field mdc-text-field--full-width">
        <label for="{{ form.description.vars.id }}">Description</label>
        {{ form_widget(form.description, {attr: {'data-comic-form-target': 'description'}}) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="form-row">
        <div class="mdc-text-field">
            <label for="{{ form.type.vars.id }}">Type</label>
            {{ form_widget(form.type, {attr: {'data-comic-form-target': 'type'}}) }}
            {{ form_errors(form.type) }}
        </div>

        <div class="mdc-text-field">
            <label for="{{ form.status.vars.id }}">Statut</label>
            {{ form_widget(form.status) }}
            {{ form_errors(form.status) }}
        </div>
    </div>

    <div class="form-row" data-comic-form-target="publishedIssueRow">
        <div class="input-group-with-checkbox">
            <label class="input-label" for="{{ form.latestPublishedIssue.vars.id }}">Dernier tome paru</label>
            <div class="input-row">
                {{ form_widget(form.latestPublishedIssue, {attr: {'data-comic-form-target': 'latestPublishedIssue'}}) }}
                <label class="checkbox-inline">
                    {{ form_widget(form.latestPublishedIssueComplete, {attr: {'data-comic-form-target': 'latestPublishedIssueComplete'}}) }}
                    <span>Serie terminee</span>
                </label>
            </div>
            {{ form_errors(form.latestPublishedIssue) }}
        </div>
    </div>

    <div class="checkboxes-row">
        <div class="mdc-checkbox-field">
            {{ form_widget(form.isOneShot, {attr: {'data-comic-form-target': 'isOneShot', 'data-action': 'change->comic-form#toggleOneShot'}}) }}
            <label for="{{ form.isOneShot.vars.id }}">One-shot (tome unique)</label>
        </div>
        <div class="mdc-checkbox-field">
            {{ form_widget(form.isWishlist) }}
            <label for="{{ form.isWishlist.vars.id }}">Dans la liste de souhaits</label>
        </div>
    </div>

    {# Section Tomes #}
    <fieldset class="tomes-section" data-comic-form-target="tomesSection">
        <legend>Tomes</legend>

        <div class="tomes-summary" data-tomes-collection-target="summary">
            {% set ownedNumbers = form.vars.data.ownedTomesNumbers %}
            {% set missingNumbers = form.vars.data.missingTomesNumbers %}
            {% if ownedNumbers|length > 0 %}
                <div class="tomes-summary-row">
                    <span class="tomes-summary-label">Possedes :</span>
                    <span class="tomes-summary-value">{{ ownedNumbers|join(', ') }}</span>
                </div>
            {% endif %}
            {% if missingNumbers|length > 0 %}
                <div class="tomes-summary-row">
                    <span class="tomes-summary-label">Manquants :</span>
                    <span class="tomes-summary-value warning">{{ missingNumbers|join(', ') }}</span>
                </div>
            {% endif %}
        </div>

        <div class="tomes-list" data-tomes-collection-target="list" data-comic-form-target="tomesList">
            {% for tome in form.tomes %}
                <div class="tome-entry" data-tomes-collection-target="entry">
                    <div class="tome-fields">
                        <div class="tome-number">
                            {{ form_widget(tome.number, {attr: {class: 'tome-number-input'}}) }}
                        </div>
                        <div class="tome-title">
                            {{ form_widget(tome.title, {attr: {placeholder: 'Titre (optionnel)'}}) }}
                        </div>
                        <div class="tome-isbn">
                            {{ form_widget(tome.isbn, {attr: {placeholder: 'ISBN'}}) }}
                        </div>
                        <div class="tome-checkboxes">
                            <label class="tome-checkbox">
                                {{ form_widget(tome.bought) }}
                                <span>Achete</span>
                            </label>
                            <label class="tome-checkbox">
                                {{ form_widget(tome.downloaded) }}
                                <span>DL</span>
                            </label>
                            <label class="tome-checkbox">
                                {{ form_widget(tome.onNas) }}
                                <span>NAS</span>
                            </label>
                        </div>
                        <button type="button" class="btn btn-icon btn-danger tome-remove" data-action="tomes-collection#removeTome" title="Supprimer ce tome">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                        </button>
                    </div>
                </div>
            {% endfor %}
        </div>

        <template data-tomes-collection-target="prototype" data-comic-form-target="tomesPrototype">
            <div class="tome-entry" data-tomes-collection-target="entry">
                <div class="tome-fields">
                    <div class="tome-number">
                        <input type="number" name="{{ form.tomes.vars.full_name }}[__name__][number]" class="tome-number-input" min="0" placeholder="N°" required>
                    </div>
                    <div class="tome-title">
                        <input type="text" name="{{ form.tomes.vars.full_name }}[__name__][title]" placeholder="Titre (optionnel)">
                    </div>
                    <div class="tome-isbn">
                        <input type="text" name="{{ form.tomes.vars.full_name }}[__name__][isbn]" placeholder="ISBN">
                    </div>
                    <div class="tome-checkboxes">
                        <label class="tome-checkbox">
                            <input type="checkbox" name="{{ form.tomes.vars.full_name }}[__name__][bought]" value="1">
                            <span>Achete</span>
                        </label>
                        <label class="tome-checkbox">
                            <input type="checkbox" name="{{ form.tomes.vars.full_name }}[__name__][downloaded]" value="1">
                            <span>DL</span>
                        </label>
                        <label class="tome-checkbox">
                            <input type="checkbox" name="{{ form.tomes.vars.full_name }}[__name__][onNas]" value="1">
                            <span>NAS</span>
                        </label>
                    </div>
                    <button type="button" class="btn btn-icon btn-danger tome-remove" data-action="tomes-collection#removeTome" title="Supprimer ce tome">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                    </button>
                </div>
            </div>
        </template>

        <div class="tomes-actions" data-comic-form-target="tomesActions">
            <button type="button" class="btn btn-outlined" data-action="tomes-collection#addTome" data-comic-form-target="addTomeButton">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg>
                Ajouter un tome
            </button>
        </div>
    </fieldset>

    <div class="form-actions">
        <a href="{{ app.request.headers.get('referer') ?: path('app_home') }}" class="btn btn-text">Annuler</a>
        <button type="submit" class="btn btn-contained">Enregistrer</button>
    </div>
{{ form_end(form) }}
