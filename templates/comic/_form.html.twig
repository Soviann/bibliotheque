{{ form_start(form, {attr: {class: 'comic-form', 'data-controller': 'comic-form'}}) }}
    <div class="form-row">
        <div class="mdc-text-field">
            <label for="{{ form.title.vars.id }}">Titre de la serie</label>
            {{ form_widget(form.title, {attr: {'data-comic-form-target': 'title'}}) }}
            {{ form_errors(form.title) }}
        </div>

        <div class="mdc-text-field isbn-field">
            <label for="{{ form.isbn.vars.id }}">ISBN</label>
            <div class="isbn-input-group">
                {{ form_widget(form.isbn, {attr: {placeholder: 'Ex: 978-2-505-00123-4', 'data-comic-form-target': 'isbn'}}) }}
                <button type="button" class="btn btn-icon" data-comic-form-target="lookupButton" data-action="comic-form#lookupIsbn" title="Rechercher par ISBN">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                </button>
            </div>
            <span class="lookup-status" data-comic-form-target="lookupStatus"></span>
            {{ form_errors(form.isbn) }}
        </div>
    </div>

    <div class="form-row">
        <div class="mdc-text-field mdc-text-field--autocomplete" data-comic-form-target="authorsWrapper">
            <label for="{{ form.authors.vars.id }}">Auteur(s)</label>
            {{ form_widget(form.authors) }}
            {{ form_errors(form.authors) }}
        </div>

        <div class="mdc-text-field">
            <label for="{{ form.publisher.vars.id }}">Editeur</label>
            {{ form_widget(form.publisher, {attr: {'data-comic-form-target': 'publisher'}}) }}
            {{ form_errors(form.publisher) }}
        </div>
    </div>

    <div class="form-row">
        <div class="mdc-text-field">
            <label for="{{ form.publishedDate.vars.id }}">Date de publication</label>
            {{ form_widget(form.publishedDate, {attr: {'data-comic-form-target': 'publishedDate'}}) }}
            {{ form_errors(form.publishedDate) }}
        </div>

        <div class="mdc-text-field">
            <label for="{{ form.coverUrl.vars.id }}">URL de la couverture (externe)</label>
            {{ form_widget(form.coverUrl, {attr: {'data-comic-form-target': 'coverUrl'}}) }}
            {{ form_errors(form.coverUrl) }}
        </div>
    </div>

    <div class="form-row cover-upload-section">
        <div class="mdc-text-field mdc-text-field--full-width cover-upload-field">
            <label>Image de couverture (upload manuel)</label>
            {% if form.vars.data.coverImage %}
                <div class="current-cover">
                    <img src="{{ vich_uploader_asset(form.vars.data, 'coverFile') }}" alt="Couverture actuelle">
                    <small>Image actuelle (sera remplacee si vous uploadez une nouvelle image)</small>
                </div>
            {% endif %}
            {{ form_widget(form.coverFile) }}
            {{ form_errors(form.coverFile) }}
            <small class="form-hint">Glissez une image ou cliquez pour parcourir. Formats : JPEG, PNG, GIF, WebP. Max : 5 Mo.</small>
        </div>
    </div>

    <div class="mdc-text-field mdc-text-field--full-width">
        <label for="{{ form.description.vars.id }}">Description</label>
        {{ form_widget(form.description, {attr: {'data-comic-form-target': 'description'}}) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="form-row">
        <div class="mdc-text-field">
            <label for="{{ form.type.vars.id }}">Type</label>
            {{ form_widget(form.type) }}
            {{ form_errors(form.type) }}
        </div>

        <div class="mdc-text-field">
            <label for="{{ form.status.vars.id }}">Statut</label>
            {{ form_widget(form.status) }}
            {{ form_errors(form.status) }}
        </div>
    </div>

    <div class="form-row">
        <div class="input-group-with-checkbox">
            <label class="input-label" for="{{ form.currentIssue.vars.id }}">Numero actuel possede</label>
            <div class="input-row">
                {{ form_widget(form.currentIssue) }}
                <label class="checkbox-inline">
                    {{ form_widget(form.currentIssueComplete) }}
                    <span>Complet</span>
                </label>
            </div>
            {{ form_errors(form.currentIssue) }}
        </div>

        <div class="input-group-with-checkbox">
            <label class="input-label" for="{{ form.lastBought.vars.id }}">Dernier numero achete</label>
            <div class="input-row">
                {{ form_widget(form.lastBought) }}
                <label class="checkbox-inline">
                    {{ form_widget(form.lastBoughtComplete) }}
                    <span>Complet</span>
                </label>
            </div>
            {{ form_errors(form.lastBought) }}
        </div>
    </div>

    <div class="form-row">
        <div class="input-group-with-checkbox">
            <label class="input-label" for="{{ form.publishedCount.vars.id }}">Nombre de parutions</label>
            <div class="input-row">
                {{ form_widget(form.publishedCount) }}
                <label class="checkbox-inline">
                    {{ form_widget(form.publishedCountComplete) }}
                    <span>Complet</span>
                </label>
            </div>
            {{ form_errors(form.publishedCount) }}
        </div>

        <div class="input-group-with-checkbox">
            <label class="input-label" for="{{ form.lastDownloaded.vars.id }}">Dernier telecharge</label>
            <div class="input-row">
                {{ form_widget(form.lastDownloaded) }}
                <label class="checkbox-inline">
                    {{ form_widget(form.lastDownloadedComplete) }}
                    <span>Complet</span>
                </label>
            </div>
            {{ form_errors(form.lastDownloaded) }}
        </div>
    </div>

    <div class="form-row">
        <div class="mdc-text-field">
            <label for="{{ form.ownedIssues.vars.id }}">Tomes possedes (si non consecutifs)</label>
            {{ form_widget(form.ownedIssues, {attr: {placeholder: 'Ex: 8, 9, 16-18, 20'}}) }}
            {{ form_errors(form.ownedIssues) }}
        </div>

        <div class="mdc-text-field">
            <label for="{{ form.missingIssues.vars.id }}">Tomes manquants</label>
            {{ form_widget(form.missingIssues, {attr: {placeholder: 'Ex: 0, 3, 5'}}) }}
            {{ form_errors(form.missingIssues) }}
        </div>
    </div>

    <div class="checkboxes-row">
        <div class="mdc-checkbox-field">
            {{ form_widget(form.onNas) }}
            <label for="{{ form.onNas.vars.id }}">Present sur le NAS</label>
        </div>

        <div class="mdc-checkbox-field">
            {{ form_widget(form.isWishlist) }}
            <label for="{{ form.isWishlist.vars.id }}">Dans la liste de souhaits</label>
        </div>
    </div>

    <div class="form-actions">
        <a href="{{ app.request.headers.get('referer') ?: path('app_home') }}" class="btn btn-text">Annuler</a>
        <button type="submit" class="btn btn-contained">Enregistrer</button>
    </div>
{{ form_end(form) }}
