<div class="comic-card">
    <a href="{{ path('app_comic_show', {id: comic.id}) }}" class="comic-card-link" data-turbo-frame="_top">
        {% if comic.coverImage %}
            <div class="comic-card-cover">
                <img src="{{ vich_uploader_asset(comic, 'coverFile') }}" alt="Couverture de {{ comic.title }}" loading="lazy">
            </div>
        {% elseif comic.coverUrl %}
            <div class="comic-card-cover">
                <img src="{{ comic.coverUrl }}" alt="Couverture de {{ comic.title }}" loading="lazy">
            </div>
        {% endif %}
        <div class="comic-card-content">
            <div class="comic-card-title">
                <h3>{{ comic.title }}</h3>
                <span class="status-badge status-{{ comic.status.value }}">{{ comic.status.label }}</span>
            </div>

            <div class="comic-info">
                {% set currentIssue = comic.currentIssue %}
                {% if currentIssue or comic.currentIssueComplete %}
                    <div class="comic-info-row">
                        <span class="comic-info-label">Possede</span>
                        <span class="comic-info-value">{% if comic.currentIssueComplete %}Complet{% else %}{{ currentIssue }}{% endif %}</span>
                    </div>
                {% endif %}
                {% set lastBought = comic.lastBought %}
                {% if lastBought or comic.lastBoughtComplete %}
                    <div class="comic-info-row">
                        <span class="comic-info-label">Dernier achat</span>
                        <span class="comic-info-value">{% if comic.lastBoughtComplete %}Complet{% else %}{{ lastBought }}{% endif %}</span>
                    </div>
                {% endif %}
                {% if comic.latestPublishedIssue or comic.latestPublishedIssueComplete %}
                    <div class="comic-info-row">
                        <span class="comic-info-label">Parus</span>
                        <span class="comic-info-value">{% if comic.latestPublishedIssueComplete %}{{ comic.latestPublishedIssue }} (termine){% else %}{{ comic.latestPublishedIssue }}{% endif %}</span>
                    </div>
                {% endif %}
                {% set lastDownloaded = comic.lastDownloaded %}
                {% if lastDownloaded or comic.lastDownloadedComplete %}
                    <div class="comic-info-row">
                        <span class="comic-info-label">Telecharge</span>
                        <span class="comic-info-value">{% if comic.lastDownloadedComplete %}Complet{% else %}{{ lastDownloaded }}{% endif %}</span>
                    </div>
                {% endif %}
                {% set ownedNumbers = comic.ownedTomesNumbers %}
                {% if ownedNumbers|length > 0 %}
                    <div class="comic-info-row">
                        <span class="comic-info-label">Tomes</span>
                        <span class="comic-info-value">{{ ownedNumbers|join(', ') }}</span>
                    </div>
                {% endif %}
                {% set missingNumbers = comic.missingTomesNumbers %}
                {% if missingNumbers|length > 0 %}
                    <div class="comic-info-row">
                        <span class="comic-info-label">Manquants</span>
                        <span class="comic-info-value warning">{{ missingNumbers|join(', ') }}</span>
                    </div>
                {% endif %}
            </div>

            <div class="type-badges">
                <span class="type-badge type-badge-{{ comic.type.value }}">{{ comic.type.label }}</span>
                {% set hasNasTome = comic.tomes|filter(t => t.onNas)|length > 0 %}
                {% if hasNasTome %}
                    <span class="type-badge type-badge-nas">NAS</span>
                {% endif %}
            </div>
        </div>
    </a>

    <div class="comic-card-actions">
        <a href="{{ path('app_comic_edit', {id: comic.id}) }}" class="btn btn-text" data-turbo-frame="_top">Modifier</a>

        {% if showToLibrary %}
            <form action="{{ path('app_comic_to_library', {id: comic.id}) }}" method="post" class="inline-form">
                <input type="hidden" name="_token" value="{{ csrf_token('to-library' ~ comic.id) }}">
                <button type="submit" class="btn btn-success">Ajouter</button>
            </form>
        {% endif %}

        <form action="{{ path('app_comic_delete', {id: comic.id}) }}" method="post" class="inline-form" onsubmit="return confirm('Supprimer cette serie ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ comic.id) }}">
            <button type="submit" class="btn btn-danger">Supprimer</button>
        </form>
    </div>
</div>
