{# Template pour le formulaire multi-étapes (wizard) #}
{% set stepNames = {
    'format': 'Type',
    'identification_series': 'Identification',
    'identification_oneshot': 'Identification',
    'details': 'Détails',
    'cover': 'Couverture',
    'tomes': 'Tomes'
} %}

{# Variables du flow disponibles dans la vue #}
{% set cursor = flow.vars.cursor %}
{% set visibleSteps = flow.vars.visible_steps %}
{% set currentStepName = cursor.currentStep %}

{# Barre de progression #}
<div class="wizard-progress">
    {% for name, step in visibleSteps %}
        <div class="wizard-step {{ step.is_current_step ? 'current' : '' }} {{ step.position < visibleSteps[currentStepName].position ? 'completed' : '' }}">
            <span class="step-number">{{ step.position }}</span>
            <span class="step-name">{{ stepNames[name] ?? name }}</span>
        </div>
    {% endfor %}
</div>

{{ form_start(flow, {attr: {class: 'wizard-form', 'data-turbo': 'false', 'data-controller': 'comic-form tomes-collection'}}) }}

<div class="wizard-step-content">
    {% if currentStepName == 'format' %}
        <h2>Type et format</h2>
        <p class="step-description">Choisissez le type de série, son statut et indiquez s'il s'agit d'un one-shot.</p>

        <div class="form-row">
            <div class="mdc-text-field">
                {{ form_label(flow.format.type) }}
                {{ form_widget(flow.format.type, {attr: {'data-comic-form-target': 'type'}}) }}
                {{ form_errors(flow.format.type) }}
            </div>

            <div class="mdc-text-field">
                {{ form_label(flow.format.status) }}
                {{ form_widget(flow.format.status) }}
                {{ form_errors(flow.format.status) }}
            </div>
        </div>

        <div class="checkboxes-row">
            <div class="mdc-checkbox-field">
                {{ form_widget(flow.format.isOneShot, {attr: {'data-comic-form-target': 'isOneShot'}}) }}
                {{ form_label(flow.format.isOneShot) }}
            </div>
        </div>

    {% elseif currentStepName == 'identification_series' %}
        <h2>Identification de la série</h2>
        <p class="step-description">Entrez le titre de la série.</p>

        <div class="form-row">
            <div class="mdc-text-field mdc-text-field--with-button">
                {{ form_label(flow.identification_series.title) }}
                <div class="input-with-button">
                    {{ form_widget(flow.identification_series.title, {attr: {'data-comic-form-target': 'title'}}) }}
                    <button type="button" class="btn btn-secondary btn-icon" data-action="comic-form#lookupByTitle" title="Rechercher via le titre">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                    </button>
                </div>
                {{ form_errors(flow.identification_series.title) }}
            </div>
        </div>

    {% elseif currentStepName == 'identification_oneshot' %}
        <h2>Identification du one-shot</h2>
        <p class="step-description">Entrez le titre du one-shot.</p>

        <div class="form-row">
            <div class="mdc-text-field mdc-text-field--with-button">
                {{ form_label(flow.identification_oneshot.title) }}
                <div class="input-with-button">
                    {{ form_widget(flow.identification_oneshot.title, {attr: {'data-comic-form-target': 'title'}}) }}
                    <button type="button" class="btn btn-secondary btn-icon" data-action="comic-form#lookupByTitle" title="Rechercher via le titre">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                    </button>
                </div>
                {{ form_errors(flow.identification_oneshot.title) }}
            </div>
        </div>

    {% elseif currentStepName == 'details' %}
        <h2>Détails</h2>
        <p class="step-description">Ajoutez les informations complémentaires.</p>

        <div class="form-row">
            <div class="mdc-text-field mdc-text-field--autocomplete">
                {{ form_label(flow.details.authors) }}
                {{ form_widget(flow.details.authors) }}
                {{ form_errors(flow.details.authors) }}
            </div>

            <div class="mdc-text-field">
                {{ form_label(flow.details.publisher) }}
                {{ form_widget(flow.details.publisher, {attr: {'data-comic-form-target': 'publisher'}}) }}
                {{ form_errors(flow.details.publisher) }}
            </div>
        </div>

        <div class="form-row">
            <div class="mdc-text-field">
                {{ form_label(flow.details.publishedDate) }}
                {{ form_widget(flow.details.publishedDate, {attr: {'data-comic-form-target': 'publishedDate'}}) }}
                {{ form_errors(flow.details.publishedDate) }}
            </div>
        </div>

        <div class="mdc-text-field mdc-text-field--full-width">
            {{ form_label(flow.details.description) }}
            {{ form_widget(flow.details.description, {attr: {'data-comic-form-target': 'description'}}) }}
            {{ form_errors(flow.details.description) }}
        </div>

    {% elseif currentStepName == 'cover' %}
        <h2>Couverture</h2>
        <p class="step-description">Ajoutez une image de couverture (optionnel).</p>

        <div class="form-row">
            <div class="mdc-text-field">
                {{ form_label(flow.cover.coverUrl) }}
                {{ form_widget(flow.cover.coverUrl, {attr: {'data-comic-form-target': 'coverUrl'}}) }}
                {{ form_errors(flow.cover.coverUrl) }}
            </div>
        </div>

        <div class="form-row cover-upload-section">
            <div class="mdc-text-field mdc-text-field--full-width cover-upload-field">
                {{ form_label(flow.cover.coverFile) }}
                {{ form_widget(flow.cover.coverFile) }}
                {{ form_errors(flow.cover.coverFile) }}
                <small class="form-hint">Glissez une image ou cliquez pour parcourir. Formats : JPEG, PNG, GIF, WebP. Max : 5 Mo.</small>
            </div>
        </div>

    {% elseif currentStepName == 'tomes' %}
        <h2>Tomes</h2>
        <p class="step-description">Gérez votre collection de tomes.</p>

        <div class="form-row">
            <div class="mdc-text-field">
                {{ form_label(flow.tomes.latestPublishedIssue) }}
                {{ form_widget(flow.tomes.latestPublishedIssue, {attr: {'data-comic-form-target': 'latestPublishedIssue'}}) }}
                {{ form_errors(flow.tomes.latestPublishedIssue) }}
            </div>
        </div>

        <fieldset class="tomes-section">
            <legend>Tomes possédés</legend>

            <div class="tomes-list" data-tomes-collection-target="list">
                {% for tome in flow.tomes.tomes %}
                    <div class="tome-entry" data-tomes-collection-target="entry">
                        <div class="tome-fields">
                            <div class="tome-number">
                                {{ form_widget(tome.number, {attr: {class: 'tome-number-input'}}) }}
                            </div>
                            <div class="tome-title">
                                {{ form_widget(tome.title, {attr: {placeholder: 'Titre (optionnel)'}}) }}
                            </div>
                            <div class="tome-isbn">
                                {{ form_widget(tome.isbn, {attr: {placeholder: 'ISBN', class: 'tome-isbn-input'}}) }}
                            </div>
                            <div class="tome-checkboxes">
                                <label class="tome-checkbox">
                                    {{ form_widget(tome.bought) }}
                                    <span>Acheté</span>
                                </label>
                                <label class="tome-checkbox">
                                    {{ form_widget(tome.downloaded) }}
                                    <span>DL</span>
                                </label>
                                <label class="tome-checkbox">
                                    {{ form_widget(tome.onNas) }}
                                    <span>NAS</span>
                                </label>
                            </div>
                            <button type="button" class="btn btn-icon btn-danger tome-remove" data-action="tomes-collection#removeTome" title="Supprimer ce tome">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="tomes-actions">
                <button type="button" class="btn btn-outlined" data-action="tomes-collection#addTome">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg>
                    Ajouter un tome
                </button>
            </div>
        </fieldset>

        {# Marque les champs restants de l'étape comme rendus #}
        {{ form_rest(flow.tomes) }}
    {% endif %}
</div>

{# Navigation du wizard #}
<div class="wizard-navigation">
    <div>
        {% if flow.previous is defined %}
            {{ form_widget(flow.previous) }}
        {% endif %}
    </div>
    <div>
        {% if flow.next is defined %}
            {{ form_widget(flow.next) }}
        {% endif %}
        {% if flow.finish is defined %}
            {{ form_widget(flow.finish) }}
        {% endif %}
    </div>
</div>

{{ form_end(flow) }}
