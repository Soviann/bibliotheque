{% extends 'base.html.twig' %}

{% block title %}Recherche - Ma Bibliotheque BD{% endblock %}

{% block body %}
<div class="page-header">
    <h1>Recherche</h1>
</div>

<div class="search-container" {{ stimulus_controller('search') }}>
    <form action="{{ path('app_search') }}" method="get" class="search-field">
        <input
            type="search"
            name="q"
            value="{{ query }}"
            placeholder="Rechercher une serie..."
            {{ stimulus_action('search', 'search', 'input') }}
            {{ stimulus_target('search', 'input') }}
            autofocus
        >
        <button type="submit">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
            </svg>
        </button>
    </form>

    <turbo-frame id="search-results" {{ stimulus_target('search', 'results') }}>
        {% if query %}
            <p class="text-subtitle" style="margin-bottom: 16px;">{{ comics|length }} resultat(s) pour "{{ query }}"</p>

            {% if comics|length > 0 %}
                <div class="cards-grid">
                    {% for comic in comics %}
                        {% include 'comic/_card.html.twig' with {comic: comic, showToLibrary: comic.isWishlist} %}
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-state">
                    <p>Aucun resultat trouve pour "{{ query }}".</p>
                </div>
            {% endif %}
        {% else %}
            <div class="empty-state">
                <p>Entrez un terme de recherche pour trouver des series.</p>
            </div>
        {% endif %}
    </turbo-frame>
</div>
{% endblock %}
