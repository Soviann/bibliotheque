# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

###> doctrine/doctrine-bundle ###
# Base de données dédiée aux tests (Doctrine ajoute automatiquement le suffixe _test)
DATABASE_URL="mysql://db:db@db:3306/db?serverVersion=10.11.0-MariaDB&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/panther ###
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots
PANTHER_DEVTOOLS=0
PANTHER_EXTERNAL_BASE_URI=https://test.bibliotheque.ddev.site
PANTHER_CHROME_DRIVER_BINARY=
###< symfony/panther ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=in-memory://
# En test, les messages sont gérés de manière synchrone
###< symfony/messenger ###

COMICVINE_API_KEY=test-comicvine-key
GEMINI_API_KEYS=test-gemini-key
OAUTH_GOOGLE_ID=test-google-client-id
OAUTH_ALLOWED_EMAIL=test@example.com
