{% extends 'base.html.twig' %}

{% block title %}Connexion - Ma Bibliotheque BD{% endblock %}

{% block body %}
<div class="login-container">
    <div class="login-card">
        <h1>Ma Bibliotheque BD</h1>
        <p class="login-subtitle">Connectez-vous pour acceder a votre collection</p>

        {% if error %}
            <div class="alert alert-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post" class="login-form">
            <div class="mdc-text-field">
                <label for="username">Email</label>
                <input type="email" id="username" name="_username" value="{{ last_username }}" required autofocus>
            </div>

            <div class="mdc-text-field">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="_password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn btn-contained" style="width: 100%; margin-top: 16px;">Se connecter</button>
        </form>
    </div>
</div>
{% endblock %}
